{
  "name": "@applyai/extension",
  "version": "0.1.0",
  "private": true,
  "description": "ApplyAI Chrome extension (Plasmo MV3)",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package"
  },
  "dependencies": {
    "plasmo": "^0.90.4",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.318",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "typescript": "^5.9.2"
  },
  "manifest": {
    "name": "ApplyAI Autofill",
    "description": "Generate grounded answers for job application fields.",
    "version": "0.1.0",
    "manifest_version": 3,
    "permissions": [
      "storage",
      "scripting",
      "activeTab"
    ],
    "host_permissions": [
      "https://*.linkedin.com/*",
      "https://*.greenhouse.io/*",
      "https://*.lever.co/*",
      "https://*.workday.com/*",
      "https://*.ashbyhq.com/*",
      "https://*.smartrecruiters.com/*"
    ],
    "externally_connectable": {
      "matches": [
        "http://localhost:3000/*",
        "https://app.applyai.app/*"
      ]
    }
  }
}